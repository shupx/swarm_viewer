{
  "name": "demo-use-micro-panel-hub",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:lib": "pnpm --dir ../micro-panel-hub build",
    "copy:sub-app": "mkdir -p dist/sub-app-demo && cp -R node_modules/@shupeixuan/micro-panel-hub/lib/sub-app-demo/. dist/sub-app-demo/",
    "sync:lib": "pnpm install --offline",
    "dev": "pnpm run build:lib && pnpm run sync:lib && webpack serve --mode development",
    "build": "pnpm run build:lib && pnpm run sync:lib && webpack --mode production && pnpm run copy:sub-app"
  },
  "dependencies": {
    "@shupeixuan/micro-panel-hub": "file:../micro-panel-hub",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "typescript": "^5.9.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
